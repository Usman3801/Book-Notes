<h1>Add a New Book to Your Tracker</h1>
<p><a href="/">Back to Dashboard</a></p>

<form action="/add" method="POST">
    <div>
        <label for="title">Book Title:</label><br>
        <input type="text" id="title" name="title" required>
    </div>
    <br>
    <div>
        <label for="author">Author:</label><br>
        <input type="text" id="author" name="author" required>
    </div>
    <br>
    <div>
        <label for="rating">Rating (1-10):</label><br>
        <input type="number" id="rating" name="rating" min="1" max="10" required>
    </div>
    <br>
    <div>
        <label for="date_read">Date Finished:</label><br>
        <input type="date" id="date_read" name="date_read" required>
    </div>
    <br>
    <div>
        <label for="isbn">ISBN Number:</label><br>
        <input type="text" id="isbn" name="isbn" placeholder="e.g., 0307474275">
    </div>
    <br>
    <div>
        <label for="notes">Your Notes & Impressions:</label><br>
        <textarea id="notes" name="notes" rows="8" cols="50" required></textarea>
    </div>
    <br>
    <button type="submit">Save Book</button>
</form>