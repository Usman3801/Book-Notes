body {
    font-family: Arial, sans-serif;
    background: #f5f5f5;
    margin: 0;
    padding: 30px;
}

.container {
    max-width: 900px;
    margin: 0 auto;
}

.book-card {
    display: flex;
    gap: 20px;
    padding: 20px;
    background: white;
    border-radius: 8px;
    margin-bottom: 20px;
}

.book-cover {
    width: 120px;
    height: auto;
    border-radius: 4px;
}

.book-cover-placeholder {
    width: 120px;
    height: 180px;
    background: #ddd;
    display: flex;
    align-items: center;
    justify-content: center;
}

.book-info {
    flex: 1;
}

.book-title {
    margin-top: 0;
}

.book-author,
.book-rating,
.book-date {
    color: #555;
}

.book-notes {
    line-height: 1.6;
}

.book-actions {
    margin-top: 15px;
    display: flex;
    gap: 10px;
}

.edit-btn,
.delete-btn,
.submit-btn,
.back-link {
    padding: 8px 14px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    border-radius: 4px;
}

.edit-btn,
.submit-btn {
    background: #2563eb;
    color: white;
}

.delete-btn {
    background: #dc2626;
    color: white;
}

.book-form {
    max-width: 700px;
    margin: 0 auto;
    background: white;
    padding: 25px;
    border-radius: 8px;
}

.form-group {
    margin-bottom: 15px;
}

.form-input,
.form-textarea {
    width: 100%;
    padding: 10px;
    margin-top: 5px;
}

.page-title {
    text-align: center;
}

.divider {
    border: none;
    border-top: 1px solid #ddd;
}